{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Quartz",
  "version": "0.1.0",
  "identifier": "com.hernan.quartz",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Quartz",
        "width": 1440,
        "height": 900,
        "minWidth": 1120,
        "minHeight": 720,
        "decorations": false,
        "shadow": true,
        "resizable": true,
        "center": true
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["$APPDATA/**", "$APPLOCALDATA/**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "createUpdaterArtifacts": true
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDEyRTIzRkZEMTFFMDc5MDIKUldRQ2VlQVIvVC9pRXViU2tzdVNtODJLR1MwN3NFd1d6ZUUycUxoNmp2Q1UwWXBGb29YUWpqc2gK",
      "endpoints": [
        "https://github.com/hernan9915/quartz/releases/latest/download/latest.json"
      ]
    }
  }
}
