<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <title>Quartz — Third-Party Licenses</title>
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <style>
    :root {
      --bg: #0a0a0c;
      --text: #efe7d6;
      --text-dim: #8a8478;
      --text-faint: #5a564e;
      --accent: #c9a96e;
      --panel: #131316;
      --line: #2a2a30;
      --serif: "Lora", "Iowan Old Style", Georgia, serif;
      --sans: -apple-system, BlinkMacSystemFont, "Segoe UI", system-ui, sans-serif;
      --mono: "JetBrains Mono", ui-monospace, "Cascadia Code", Consolas, monospace;
    }
    @media (prefers-color-scheme: light) {
      :root {
        --bg: #f5f4f1;
        --text: #1a1916;
        --text-dim: #6a6862;
        --text-faint: #95938c;
        --accent: #8a5a2a;
        --panel: #e6e4df;
        --line: #c8c5bd;
      }
    }
    * { box-sizing: border-box; }
    html, body {
      margin: 0; padding: 0;
      background: var(--bg);
      color: var(--text);
      font-family: var(--sans);
      font-size: 14px;
      line-height: 1.6;
    }
    .wrap {
      max-width: 900px;
      margin: 0 auto;
      padding: 48px 24px 96px;
    }
    h1 {
      font-family: var(--serif);
      font-style: italic;
      font-weight: 400;
      font-size: 48px;
      margin: 0 0 8px;
      letter-spacing: -0.01em;
      line-height: 1.1;
    }
    .lede {
      color: var(--text-dim);
      max-width: 640px;
      margin-bottom: 40px;
    }
    .meta {
      font-family: var(--mono);
      font-size: 11px;
      color: var(--text-faint);
      letter-spacing: 0.12em;
      text-transform: uppercase;
      margin-bottom: 14px;
    }
    .summary {
      background: var(--panel);
      border: 1px solid var(--line);
      border-radius: 4px;
      padding: 16px 20px;
      margin-bottom: 40px;
    }
    .summary h2 {
      font-family: var(--serif);
      font-style: italic;
      font-weight: 400;
      font-size: 18px;
      margin: 0 0 12px;
    }
    .license-row {
      display: grid;
      grid-template-columns: 1fr auto;
      gap: 12px;
      padding: 4px 0;
      border-bottom: 1px dotted var(--line);
      font-size: 13px;
    }
    .license-row:last-child { border-bottom: 0; }
    .license-row a {
      color: var(--accent);
      text-decoration: none;
    }
    .license-row a:hover { text-decoration: underline; }
    .crate-count {
      font-family: var(--mono);
      font-size: 11px;
      color: var(--text-faint);
    }
    .license-block {
      margin-top: 48px;
      padding-top: 24px;
      border-top: 1px solid var(--line);
    }
    .license-block h2 {
      font-family: var(--serif);
      font-style: italic;
      font-weight: 400;
      font-size: 28px;
      margin: 0 0 8px;
    }
    .license-block .used-by {
      color: var(--text-dim);
      font-size: 12px;
      margin-bottom: 16px;
    }
    .license-block .used-by code {
      font-family: var(--mono);
      font-size: 11.5px;
      background: var(--panel);
      padding: 1px 5px;
      border-radius: 2px;
    }
    pre {
      font-family: var(--mono);
      font-size: 11.5px;
      line-height: 1.55;
      background: var(--panel);
      border: 1px solid var(--line);
      border-radius: 4px;
      padding: 16px 18px;
      overflow-x: auto;
      white-space: pre-wrap;
      word-break: break-word;
      color: var(--text-dim);
    }
  </style>
</head>
<body>
  <div class="wrap">
    <div class="meta">Attributions</div>
    <h1>Third-Party Licenses</h1>
    <p class="lede">
      Quartz is built on a collection of open-source libraries, all of which
      retain their original copyright. The full text of each library's
      license is included below as required by their terms.
    </p>

    <div class="summary">
      <h2>Used licenses</h2>
      {{#each overview}}
      <div class="license-row">
        <a href="#{{id}}">{{name}}</a>
        <span class="crate-count">{{count}} {{#if (eq count 1)}}crate{{else}}crates{{/if}}</span>
      </div>
      {{/each}}
    </div>

    {{#each licenses}}
    <div class="license-block" id="{{id}}">
      <h2>{{name}}</h2>
      <div class="used-by">
        Used by:
        {{#each used_by}}
        <code>{{this.crate.name}} {{this.crate.version}}</code>{{#unless @last}}, {{/unless}}
        {{/each}}
      </div>
      <pre>{{text}}</pre>
    </div>
    {{/each}}
  </div>
</body>
</html>
